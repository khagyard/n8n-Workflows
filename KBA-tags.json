      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\nconst ticket = $('Ticket Data').item.json;\nconst query = $('Store Query').item.json.kbsearch;\nconst items = $input.all();\n\nconst articles = items.map(item => ({\n  articleId: item.json.ID,\n  title: item.json.Subject,\n  category: item.json.CategoryName,\n  body: item.json.Body\n}));\n\nreturn [{\n  json: {\n    ticketId: ticket.ID || ticket.TicketID,\n    ticketTitle: ticket.Title || ticket.Subject,\n    ticketDescription: ticket.Description || ticket.Body,\n    queryUsed: query,\n    articles\n  }\n}];"
