    {
      "parameters": {
        "jsCode": "const results = [];\n\nfor (const item of $input.all()) {\n  const messageOutput = item.json.output.find(o => o.type === \"message\");\n  if (!messageOutput) continue;\n\n  let text = messageOutput.content[0].text\n    .replace(/^```json\\s*/i, \"\")\n    .replace(/^```\\s*/i, \"\")\n    .replace(/\\s*```$/, \"\")\n    .trim();\n\n  try {\n    const parsed = JSON.parse(text);\n\n    for (const a of parsed) {\n      results.push({\n        json: {\n          ...a,\n          relevanceScore: Number(a.relevanceScore)\n        }\n      });\n    }\n  } catch (err) {\n    return [{\n      json: {\n        error: err.message,\n        badText: text\n      }\n    }];\n  }\n}\n\nreturn results;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
